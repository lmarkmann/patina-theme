  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace": "#2a6361",
    "property": "#6e5831",
    "interface": "#2a6361",
    "type": "#2a6361",
    "class": "#2a6361",
    "enum": "#2a6361",
